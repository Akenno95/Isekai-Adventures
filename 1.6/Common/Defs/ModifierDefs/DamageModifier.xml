<?xml version="1.0" encoding="utf-8"?>
<Defs>

<!-- V1 Testing Basic -->
    <IsekaiAdventures.DamageModifierDef>
        <defName>Isekai_TestFlatDamageBonus</defName>
        <flatBonusDamage>5</flatBonusDamage>
    </IsekaiAdventures.DamageModifierDef>

    <HediffDef>
        <defName>Isekai_TestDamageBuff</defName>
        <label>test damage buff</label>
        <description>Test description for damage buff.</description>
        <hediffClass>HediffWithComps</hediffClass>

        <comps>
        <li Class="IsekaiAdventures.HediffCompProperties_DamageModifiers">
            <modifiers>
               <li>Isekai_TestFlatDamageBonus</li>
               <li>Isekai_TestPercentDamageBonus</li>
            </modifiers>
        </li>
        </comps>
    </HediffDef>

    <IsekaiAdventures.DamageModifierDef>
        <defName>Isekai_TestFlatDamageReduction</defName>
        <flatReduction>3</flatReduction>
    </IsekaiAdventures.DamageModifierDef>

    <HediffDef>
        <defName>Isekai_TestDamageShield</defName>
        <label>test damage shield</label>
        <description>Test description for damage shield.</description>
        <hediffClass>HediffWithComps</hediffClass>

        <comps>
            <li Class="IsekaiAdventures.HediffCompProperties_DamageModifiers">
                <modifiers>
                    <li>Isekai_TestFlatDamageReduction</li>
                    <li>Isekai_TestPercentDamageReduction</li>
                </modifiers>
            </li>
        </comps>
    </HediffDef>


    <IsekaiAdventures.DamageModifierDef>
        <defName>Isekai_TestPercentDamageBonus</defName>
        <percentBonusDamage>0.50</percentBonusDamage>
    </IsekaiAdventures.DamageModifierDef>

    <IsekaiAdventures.DamageModifierDef>
        <defName>Isekai_TestPercentDamageReduction</defName>
        <percentReduction>0.25</percentReduction>
    </IsekaiAdventures.DamageModifierDef>




    <StatDef>
    <defName>Isekai_TestPower</defName>
    <label>test power</label>
    <description>Test stat for damage scaling.</description>
    <category>PawnCombat</category>
    <displayPriorityInCategory>1000</displayPriorityInCategory>
    <defaultBaseValue>0</defaultBaseValue>
    <minValue>0</minValue>
    <!-- <toStringStyle>PercentZero</toStringStyle> -->
    </StatDef>

    <IsekaiAdventures.DamageModifierDef>
    <defName>Isekai_TestStatDamageBonus</defName>
    <percentBonusFromStat>
        <stat>Isekai_TestPower</stat>
        <factor>0.02</factor>
    </percentBonusFromStat>
    </IsekaiAdventures.DamageModifierDef>

    <HediffDef>
    <defName>Isekai_TestPowerCaster</defName>
    <label>test power caster</label>
    <description>Test description for power caster.</description>
    <hediffClass>HediffWithComps</hediffClass>

    <stages>
        <li>
        <statOffsets>
            <Isekai_TestPower>10</Isekai_TestPower>
        </statOffsets>
        </li>
    </stages>

    <comps>
        <li Class="IsekaiAdventures.HediffCompProperties_DamageModifiers">
        <modifiers>
            <li>Isekai_TestStatDamageBonus</li>
        </modifiers>
        </li>
    </comps>
    </HediffDef>

<!-- V2 Testing Stats -->
    <IsekaiAdventures.DamageModifierDef>
    <defName>Isekai_TestBluntOnlyBonus</defName>
    <damageDef>Blunt</damageDef>
    <flatBonusDamage>10</flatBonusDamage>
    </IsekaiAdventures.DamageModifierDef>

    <HediffDef>
    <defName>Isekai_TestBluntOnlyBuff</defName>
    <label>test blunt only buff</label>
    <description>Test description for blunt only buff.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <comps>
        <li Class="IsekaiAdventures.HediffCompProperties_DamageModifiers">
        <modifiers>
            <li>Isekai_TestBluntOnlyBonus</li>
        </modifiers>
        </li>
    </comps>
    </HediffDef>


    <IsekaiAdventures.DamageModifierDef>
    <defName>Isekai_MagicPowerScaling</defName>
    <damageDef>Isekai_SlashDamage</damageDef>
    <percentBonusFromStat>
        <stat>Isekai_MagicPower</stat>
        <factor>0.02</factor>
    </percentBonusFromStat>
    </IsekaiAdventures.DamageModifierDef>

    <IsekaiAdventures.DamageModifierDef>
  <defName>Isekai_MagicResistanceScaling</defName>
  <damageDef>Isekai_SlashDamage</damageDef>
  <percentReductionFromStat>
    <stat>Isekai_MagicResistance</stat>
    <factor>0.02</factor>
  </percentReductionFromStat>
    </IsekaiAdventures.DamageModifierDef>

    <StatDef>
    <defName>Isekai_MagicPower</defName>
    <label>magic power</label>
    <description>Increases magic-based damage.</description>
    <defaultBaseValue>0</defaultBaseValue>
    <minValue>0</minValue>
    <!-- <toStringStyle>PercentZero</toStringStyle> -->
    <category>PawnCombat</category>
    <displayPriorityInCategory>1000</displayPriorityInCategory>
    </StatDef>

    <StatDef>
    <defName>Isekai_MagicResistance</defName>
    <label>magic resistance</label>
    <description>Reduces incoming magic damage.</description>
    <defaultBaseValue>0</defaultBaseValue>
    <minValue>0</minValue>
    <!-- <toStringStyle>PercentZero</toStringStyle> -->
    <category>PawnCombat</category>
    <displayPriorityInCategory>1000</displayPriorityInCategory>
    </StatDef>

    <HediffDef>
    <defName>Isekai_TestMagicDmgBuff</defName>
    <label>test magic dmg only buff</label>
    <description>Test description for magic damage buff.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <stages>
        <li>
        <statOffsets>
            <Isekai_MagicPower>10</Isekai_MagicPower>
        </statOffsets>
        </li>
    </stages>
    <comps>
        <li Class="IsekaiAdventures.HediffCompProperties_DamageModifiers">
        <modifiers>
            <li>Isekai_MagicPowerScaling</li>
        </modifiers>
        </li>
    </comps>
    </HediffDef>

    <HediffDef>
    <defName>Isekai_TestMagicDefBuff</defName>
    <label>test magic def buff</label>
    <description>Test description for magic defense buff.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <stages>
        <li>
        <statOffsets>
            <Isekai_MagicResistance>10</Isekai_MagicResistance>
        </statOffsets>
        </li>
    </stages>
    <comps>
        <li Class="IsekaiAdventures.HediffCompProperties_DamageModifiers">
        <modifiers>
            <li>Isekai_MagicResistanceScaling</li>
        </modifiers>
        </li>
    </comps>
    </HediffDef>

<!-- V3 Testing DamageTypeSets -->
        <IsekaiAdventures.DamageModifierDef>
            <defName>Isekai_MagicSuperResistanceScaling</defName>
            <damageTypeSet>Isekai_MagicDamageSet</damageTypeSet>
            <percentReductionFromStat>
                <stat>Isekai_MagicResistance</stat>
                <factor>0.05</factor>
            </percentReductionFromStat>
        </IsekaiAdventures.DamageModifierDef>

        <IsekaiAdventures.DamageModifierDef>
            <defName>Isekai_MagicPowerDefenseScaling</defName>
            <damageTypeSet>Isekai_MagicDamageSet</damageTypeSet>
            <percentBonusFromStats>
                <li>
                    <stat>Isekai_MagicPower</stat>
                    <factor>0.02</factor>
                </li>
                <li>
                    <stat>Isekai_MagicResistance</stat>
                    <factor>0.01</factor>
                </li>
            </percentBonusFromStats>
        </IsekaiAdventures.DamageModifierDef>

        <HediffDef>
            <defName>Isekai_TestHolyMageBuff</defName>
            <label>test holy mage buff</label>
            <description>Test description for holy mage buff.</description>
            <hediffClass>HediffWithComps</hediffClass>
            <stages>
                <li>
                <statOffsets>
                    <Isekai_MagicPower>10</Isekai_MagicPower>
                    <Isekai_MagicResistance>15</Isekai_MagicResistance>
                </statOffsets>
                </li>
            </stages>
            <comps>
                <li Class="IsekaiAdventures.HediffCompProperties_DamageModifiers">
                <modifiers>
                    <li>Isekai_MagicPowerDefenseScaling</li>
                </modifiers>
                </li>
            </comps>
        </HediffDef>

        <HediffDef>
            <defName>Isekai_TestSuperMageBuff</defName>
            <label>test super def mage buff</label>
            <description>Test description for super mage buff.</description>
            <hediffClass>HediffWithComps</hediffClass>
            <stages>
                <li>
                <statOffsets>
                    <Isekai_MagicPower>10</Isekai_MagicPower>
                    <Isekai_MagicResistance>15</Isekai_MagicResistance>
                </statOffsets>
                </li>
            </stages>
            <comps>
                <li Class="IsekaiAdventures.HediffCompProperties_DamageModifiers">
                <modifiers>
                    <li>Isekai_MagicSuperResistanceScaling</li>
                </modifiers>
                </li>
            </comps>
        </HediffDef>


<!-- V4 Testing DamageResult -->
        <IsekaiAdventures.DamageModifierDef>
        <defName>Isekai_TestFullMagicNegation</defName>
        <damageTypeSet>Isekai_MagicDamageSet</damageTypeSet>

        <percentReduction>1.0</percentReduction>
        </IsekaiAdventures.DamageModifierDef>

        <HediffDef>
        <defName>Isekai_TestFullMagicBarrier</defName>
        <label>test full magic barrier</label>
        <description>Test description for full magic barrier.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <comps>
            <li Class="IsekaiAdventures.HediffCompProperties_DamageModifiers">
            <modifiers>
                <li>Isekai_TestFullMagicNegation</li>
            </modifiers>
            </li>
        </comps>
        </HediffDef>


<!-- V5 Testing OnHit Resolver-->
        <IsekaiAdventures.OnHitModifierDef>
            <defName>Isekai_OnHitArcaneInstability</defName>
            <damageTypeSet>Isekai_MagicDamageSet</damageTypeSet>
            <chance>1.0</chance>
            <triggerIfNoDamage>true</triggerIfNoDamage>
            <applyHediff>Isekai_ArcaneInstability</applyHediff>
            <severity>0.10</severity>
            <applyHediffToSelf>Isekai_ArcaneInstability</applyHediffToSelf>
                <severityToSelf>0.1</severityToSelf>
        </IsekaiAdventures.OnHitModifierDef>

        <HediffDef>
            <defName>Isekai_TestOnHitCaster</defName>
            <label>test on hit caster</label>
            <description>Test description for on hit caster.</description>
            <hediffClass>HediffWithComps</hediffClass>
            <comps>
                <li Class="IsekaiAdventures.HediffCompProperties_OnHitModifiers">
                    <modifiers>
                        <li>Isekai_OnHitArcaneInstability</li>
                    </modifiers>
                </li>
            </comps>
        </HediffDef>

        <HediffDef>
            <defName>Isekai_ArcaneInstability</defName>
            <label>arcane instability</label>
            <description>Test description for arcane instability.</description>
            <hediffClass>HediffWithComps</hediffClass>
            <initialSeverity>0.1</initialSeverity>
            <comps>
                <li Class="IsekaiAdventures.HediffCompProperties_DamageModifiers">
                    <minSeverity>0.2</minSeverity>
                    <modifiers>
                        <li>Isekai_DamageArcaneInstability</li>
                    </modifiers>
                </li>
            </comps>
        </HediffDef>

        <IsekaiAdventures.DamageModifierDef>
            <defName>Isekai_DamageArcaneInstability</defName>
            <damageTypeSet>Isekai_MagicDamageSet</damageTypeSet>
            <percentReduction>-1.0</percentReduction>
        </IsekaiAdventures.DamageModifierDef>


<!-- V6 Testing Damage Resolver Block/Parry with global -->
        <IsekaiAdventures.DamageModifierDef>
            <defName>Isekai_TestBlockAlways</defName>
            <damageTypeSet>Isekai_PhysicalDamageSet</damageTypeSet>
            <!-- <global>true</global> -->
            <blockChance>1.0</blockChance>
            <blockChanceFromStats>
                <li>
                    <stat>Isekai_MagicPower</stat>
                    <factor>0.01</factor>
                </li>
            </blockChanceFromStats>
        </IsekaiAdventures.DamageModifierDef>

        <HediffDef>
            <defName>Isekai_TestBlockCaster</defName>
            <label>test block caster</label>
            <description>Test description for block caster.</description>
            <hediffClass>HediffWithComps</hediffClass>
            <comps>
                <li Class="IsekaiAdventures.HediffCompProperties_DamageModifiers">
                    <modifiers>
                        <li>Isekai_TestBlockAlways</li>
                    </modifiers>
                </li>
            </comps>
        </HediffDef>

        <IsekaiAdventures.DamageModifierDef>
            <defName>Isekai_TestIgnoreBlockAlways</defName>
            <damageTypeSet>Isekai_PhysicalDamageSet</damageTypeSet>
            <!-- <global>true</global> -->
            <ignoreBlockChance>1.0</ignoreBlockChance>
            <ignoreBlockChanceFromStats>
                <li>
                    <stat>Isekai_MagicResistance</stat>
                    <factor>0.01</factor>
                </li>
            </ignoreBlockChanceFromStats>
        </IsekaiAdventures.DamageModifierDef>

        <HediffDef>
            <defName>Isekai_TestIgnoreBlockCaster</defName>
            <label>test ignore block caster</label>
            <description>Test description for ignore block caster.</description>
            <hediffClass>HediffWithComps</hediffClass>
            <comps>
                <li Class="IsekaiAdventures.HediffCompProperties_DamageModifiers">
                    <modifiers>
                        <li>Isekai_TestIgnoreBlockAlways</li>
                    </modifiers>
                </li>
            </comps>
        </HediffDef>


<!-- V7 Testing OnDamaged Resolver -->
        <IsekaiAdventures.OnDamagedModifierDef>
            <defName>Isekai_OnDamaged_ThornWound</defName>
            <damageTypeSet>Isekai_PhysicalDamageSet</damageTypeSet>
            <chance>0.0</chance>
            <chanceFromStats>
                <li>
                    <stat>Isekai_MagicPower</stat>
                    <factor>0.1</factor>
                </li>
            </chanceFromStats>
            <applyHediff>Isekai_TestThornWound</applyHediff>
            <severity>0.1</severity>
            <applyHediffToSelf>Isekai_TestBlockCaster</applyHediffToSelf>
            <severityToSelf>0.1</severityToSelf>
            <triggerIfNoDamage>true</triggerIfNoDamage>
            <triggerIfBlocked>true</triggerIfBlocked>
        </IsekaiAdventures.OnDamagedModifierDef>

        <HediffDef>
            <defName>Isekai_TestThornArmor</defName>
            <label>test thorn armor</label>
            <hediffClass>HediffWithComps</hediffClass>
            <comps>
                <li Class="IsekaiAdventures.HediffCompProperties_OnDamagedModifiers">
                <modifiers>
                    <li>Isekai_OnDamaged_ThornWound</li>
                </modifiers>
                </li>
            </comps>
        </HediffDef>

        <HediffDef>
            <defName>Isekai_TestThornWound</defName>
            <label>test thorn wound</label>
            <hediffClass>HediffWithComps</hediffClass>
        </HediffDef>

<!-- V8 Testing ComboReaction -->
     <HediffDef>
        <defName>Isekai_TestWet</defName>
        <label>test wet</label>
        <description>Test wet state for combo reactions.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <initialSeverity>0.4</initialSeverity>
        <maxSeverity>10</maxSeverity>
    </HediffDef>

    <HediffDef>
        <defName>Isekai_TestDrenched</defName>
        <label>test drenched</label>
        <description>Alternative wet state for HediffSet testing.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <initialSeverity>0.4</initialSeverity>
        <maxSeverity>10</maxSeverity>
    </HediffDef>

    <HediffDef>
        <defName>Isekai_TestLightningCharge</defName>
        <label>test lightning charge</label>
        <description>Test lightning state for hediff-triggered combo reactions.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <initialSeverity>0.1</initialSeverity>
        <maxSeverity>10</maxSeverity>
    </HediffDef>

    <HediffDef>
        <defName>Isekai_TestStaticCharge</defName>
        <label>test static charge</label>
        <description>Alternative lightning state for HediffSet testing.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <initialSeverity>0.1</initialSeverity>
        <maxSeverity>10</maxSeverity>
    </HediffDef>

    <HediffDef>
        <defName>Isekai_TestShocked</defName>
        <label>test shocked</label>
        <description>Applied by ComboReaction.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <initialSeverity>0.1</initialSeverity>
        <maxSeverity>10</maxSeverity>
    </HediffDef>

    <IsekaiAdventures.HediffSetDef>
        <defName>Isekai_HediffSet_WetStates</defName>
        <label>wet states</label>
        <hediffs>
            <li>Isekai_TestWet</li>
            <li>Isekai_TestDrenched</li>
        </hediffs>
    </IsekaiAdventures.HediffSetDef>

    <IsekaiAdventures.HediffSetDef>
        <defName>Isekai_HediffSet_LightningStates</defName>
        <label>lightning states</label>
        <hediffs>
            <li>Isekai_TestLightningCharge</li>
            <li>Isekai_TestStaticCharge</li>
        </hediffs>
    </IsekaiAdventures.HediffSetDef>

    <IsekaiAdventures.ComboTriggerSetDef>
        <defName>Isekai_TriggerSet_TestLightning</defName>
        <label>test lightning triggers</label>

        <!-- Damage trigger for easy melee testing -->
        <damageDefs>
            <li>Blunt</li>
        </damageDefs>

        <!-- Hediff trigger for AddHediff testing -->
        <hediffSets>
            <li>Isekai_HediffSet_LightningStates</li>
        </hediffSets>
    </IsekaiAdventures.ComboTriggerSetDef>

    <IsekaiAdventures.ComboReactionModifierDef>
        <defName>Isekai_Combo_Test_WetLightningShock_Main</defName>
        <global>true</global>
        <!-- triggerMode omitted = Any -->

        <triggerSet>Isekai_TriggerSet_TestLightning</triggerSet>

        <requiredHediffs>
            <li>
                <hediffSet>Isekai_HediffSet_WetStates</hediffSet>
                <severity>0.5</severity>
            </li>
        </requiredHediffs>

        <!-- consume omitted = true -->
        <!-- matched requiredHediffs are removed completely -->

        <applyHediff>Isekai_TestShocked</applyHediff>
        <severity>0.25</severity>
    </IsekaiAdventures.ComboReactionModifierDef>

</Defs>