  <!-- ============================================================ -->
  <!-- 5) OPTIONAL DEBUG NOTES                                       -->
  <!--                                                              -->
  <!-- Current test status before HediffComp_HealPipeline exists:    -->
  <!-- - Anti-heal should already affect vanilla Hediff_Injury.Heal. -->
  <!-- - Half/double heal should affect vanilla Hediff_Injury.Heal.  -->
  <!-- - Custom Amount/Slots/Speed values are collected by resolver, -->
  <!--   but need an active HealPipeline comp to visibly execute.    -->
  <!-- ============================================================ -->

  <IsekaiAdventures.HealModifierDef>
    <defName>Isekai_HealModifier_TEST_5Healing</defName>
    <label>test: 5 healing</label>
    <description>Multiplies all healing by 5.</description>
    <healTypeSets>
      <li>Isekai_HealSet_AllCustom</li>
    </healTypeSets>
    <totalHealFactor>5</totalHealFactor>
    <global>true</global>
  </IsekaiAdventures.HealModifierDef>


 <HediffDef>
    <defName>Isekai_TEST_HealPulse_FullTest</defName>
    <label>heal pulse: full test</label>
    <description>Test hediff: enables injury healing, auto tend, scar healing and regrowth.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <comps>
      <li Class="IsekaiAdventures.HediffCompProperties_HealPulse">
        <!-- <severityOffset>-0.1</severityOffset> -->
        <debug>true</debug>
        <pulseImmediately>true</pulseImmediately>
        <healInjuries>true</healInjuries>
        <injuryHealIntervalTicks>60</injuryHealIntervalTicks>
        <injuryHealAmount>0.1</injuryHealAmount>
        <injuryHealSlots>1</injuryHealSlots>
        <injuryHealSpeed>1</injuryHealSpeed>

        <tendWounds>true</tendWounds>
        <tendIntervalTicks>60</tendIntervalTicks>
        <tendQuality>0.1</tendQuality>
        <tendSlots>1</tendSlots>
        <tendSpeed>1</tendSpeed>
        <tendBleedingOnly>true</tendBleedingOnly>
        <tendFreshMissingParts>true</tendFreshMissingParts>

        <healScars>true</healScars>
        <scarHealIntervalTicks>180</scarHealIntervalTicks>
        <scarHealAmount>0.5</scarHealAmount>
        <scarHealSlots>1</scarHealSlots>
        <scarHealSpeed>1</scarHealSpeed>

        <healNonInjuryHediffs>false</healNonInjuryHediffs>

        <regrowParts>true</regrowParts>
        <regrowthIntervalTicks>60</regrowthIntervalTicks>
        <regrowthWorkRequiredTicks>1800</regrowthWorkRequiredTicks>
        <regrowthSlots>1</regrowthSlots>
        <regrowthSpeed>1</regrowthSpeed>
        <regrowthWorkFactor>1</regrowthWorkFactor>

        <scaleRegrowthWorkByPartSize>false</scaleRegrowthWorkByPartSize>
        <regrowthIndicatorHediff>Isekai_Hediff_RegrowthIndicator</regrowthIndicatorHediff>
        <removeIndicatorOnComplete>true</removeIndicatorOnComplete>
      </li>
    </comps>
  </HediffDef>












</Defs>
