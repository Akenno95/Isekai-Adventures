<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <!-- ============================================================ -->
  <!-- 3) HEALMODIFIERDEFS                                           -->
  <!--                                                              -->
  <!-- Important rules:                                             -->
  <!-- - No <values> list anymore.                                  -->
  <!-- - Fixed modifiers are direct fields.                         -->
  <!-- - totalHealFactor is multiplicative and explicit.            -->
  <!-- - totalHealFactor 1 = neutral.                               -->
  <!-- - totalHealFactor 0 = healing completely blocked.            -->
  <!-- - global defaults to false, so it is omitted here.            -->
  <!-- ============================================================ -->


  <!-- ============================================================ -->
  <!-- TEST 1: Complete Anti-Heal                                    -->
  <!-- Expected:                                                     -->
  <!-- - Custom healing becomes 0.                                   -->
  <!-- - Regrowth progress becomes 0 when used by active HealComp.   -->
  <!-- - Vanilla Hediff_Injury.Heal is blocked through patch.        -->
  <!-- ============================================================ -->

  <IsekaiAdventures.HealModifierDef>
    <defName>Isekai_HealModifier_TEST_BlockAllHealing</defName>
    <label>test: block all healing</label>
    <description>Sets TotalHealFactor to 0. This should block all healing while active.</description>
    <healTypeSets>
      <li>Isekai_HealSet_AllIncludingVanilla</li>
    </healTypeSets>
    <totalHealFactor>0</totalHealFactor>
  </IsekaiAdventures.HealModifierDef>


  <!-- ============================================================ -->
  <!-- TEST 2A: Half Healing A                                       -->
  <!-- Expected alone: TotalHealFactor = 0.5.                        -->
  <!-- Expected with Half Healing B: 0.5 * 0.5 = 0.25.               -->
  <!-- ============================================================ -->

  <IsekaiAdventures.HealModifierDef>
    <defName>Isekai_HealModifier_TEST_HalfHealing_A</defName>
    <label>test: half healing A</label>
    <description>Multiplies all healing by 0.5.</description>
    <healTypeSets>
      <li>Isekai_HealSet_AllIncludingVanilla</li>
    </healTypeSets>
    <totalHealFactor>0.5</totalHealFactor>
  </IsekaiAdventures.HealModifierDef>


  <!-- ============================================================ -->
  <!-- TEST 2B: Half Healing B                                       -->
  <!-- Separate modifier so stacking can be tested.                  -->
  <!-- The collector deduplicates identical HealModifierDefs, so      -->
  <!-- two different modifier defs are used for stack testing.        -->
  <!-- ============================================================ -->

  <IsekaiAdventures.HealModifierDef>
    <defName>Isekai_HealModifier_TEST_HalfHealing_B</defName>
    <label>test: half healing B</label>
    <description>Multiplies all healing by 0.5. Used to test multiplicative stacking.</description>
    <healTypeSets>
      <li>Isekai_HealSet_AllIncludingVanilla</li>
    </healTypeSets>
    <totalHealFactor>0.5</totalHealFactor>
  </IsekaiAdventures.HealModifierDef>


  <!-- ============================================================ -->
  <!-- TEST 3: Double Healing                                        -->
  <!-- Expected: TotalHealFactor = 2.                                -->
  <!-- Note: Vanilla healing is also doubled through TotalHealFactor. -->
  <!-- ============================================================ -->

  <IsekaiAdventures.HealModifierDef>
    <defName>Isekai_HealModifier_TEST_DoubleHealing</defName>
    <label>test: double healing</label>
    <description>Multiplies all healing by 2.</description>
    <healTypeSets>
      <li>Isekai_HealSet_AllIncludingVanilla</li>
    </healTypeSets>
    <totalHealFactor>2</totalHealFactor>
  </IsekaiAdventures.HealModifierDef>


  <!-- ============================================================ -->
  <!-- TEST 4: Body Restoration Boost                                -->
  <!-- Expected:                                                     -->
  <!-- - Custom Injury healing stronger/faster.                      -->
  <!-- - Custom Scar healing stronger/faster.                        -->
  <!-- - Custom Regrowth gets more slots and speed.                  -->
  <!-- - Vanilla healing is NOT increased unless totalHealFactor      -->
  <!--   is changed separately.                                      -->
  <!-- ============================================================ -->

  <IsekaiAdventures.HealModifierDef>
    <defName>Isekai_HealModifier_TEST_BodyRestorationBoost</defName>
    <label>test: body restoration boost</label>
    <description>Boosts custom injury, scar and regrowth healing.</description>
    <healTypeSets>
      <li>Isekai_HealSet_BodyRestoration</li>
    </healTypeSets>

    <injuryHealAmount>0.10</injuryHealAmount>
    <injuryHealPercentOfMissing>0.05</injuryHealPercentOfMissing>
    <injuryHealSpeed>1.0</injuryHealSpeed>
    <injuryHealSlots>1</injuryHealSlots>

    <scarHealAmount>0.02</scarHealAmount>
    <scarHealSpeed>0.5</scarHealSpeed>
    <scarHealSlots>1</scarHealSlots>

    <regrowthSlots>1</regrowthSlots>
    <regrowthSpeed>1.0</regrowthSpeed>
  </IsekaiAdventures.HealModifierDef>


  <!-- ============================================================ -->
  <!-- TEST 5: Auto Tend Boost                                       -->
  <!-- Expected when active HealComp supports Tend:                  -->
  <!-- - TendQuality +0.25                                           -->
  <!-- - TendSlots +2                                                -->
  <!-- - TendSpeed +1.0                                              -->
  <!-- ============================================================ -->

  <IsekaiAdventures.HealModifierDef>
    <defName>Isekai_HealModifier_TEST_AutoTendBoost</defName>
    <label>test: auto tend boost</label>
    <description>Boosts automatic tending values only.</description>
    <healDefs>
      <li>Isekai_Heal_Tend</li>
    </healDefs>

    <tendQuality>0.25</tendQuality>
    <tendSlots>2</tendSlots>
    <tendSpeed>1.0</tendSpeed>
  </IsekaiAdventures.HealModifierDef>


  <!-- ============================================================ -->
  <!-- TEST 6: Regrowth Specialist                                   -->
  <!-- Expected when active HealComp supports Regrowth:              -->
  <!-- - RegrowthSlots +2                                            -->
  <!-- - RegrowthSpeed +1.0                                          -->
  <!-- - RegrowthWorkFactor -0.25                                    -->
  <!-- If base work factor is 1, final work factor becomes 0.75.      -->
  <!-- ============================================================ -->

  <IsekaiAdventures.HealModifierDef>
    <defName>Isekai_HealModifier_TEST_RegrowthSpecialist</defName>
    <label>test: regrowth specialist</label>
    <description>Boosts only regrowth values.</description>
    <healDefs>
      <li>Isekai_Heal_Regrowth</li>
    </healDefs>

    <regrowthSlots>2</regrowthSlots>
    <regrowthSpeed>1.0</regrowthSpeed>
    <regrowthWorkFactor>-0.25</regrowthWorkFactor>
  </IsekaiAdventures.HealModifierDef>


  <!-- ============================================================ -->
  <!-- TEST 7: Scar and Severity Cleaner                             -->
  <!-- Expected when active HealComp supports Scar/HediffSeverity:   -->
  <!-- - Scar and non-injury severity reduction are boosted.         -->
  <!-- ============================================================ -->

  <IsekaiAdventures.HealModifierDef>
    <defName>Isekai_HealModifier_TEST_SeverityCleaner</defName>
    <label>test: severity cleaner</label>
    <description>Boosts scar and non-injury hediff severity healing.</description>
    <healTypeSets>
      <li>Isekai_HealSet_SeverityReduction</li>
    </healTypeSets>

    <scarHealAmount>0.03</scarHealAmount>
    <scarHealSpeed>1.0</scarHealSpeed>
    <scarHealSlots>1</scarHealSlots>

    <hediffSeverityHealAmount>0.02</hediffSeverityHealAmount>
    <hediffSeverityHealSpeed>1.0</hediffSeverityHealSpeed>
    <hediffSeverityHealSlots>1</hediffSeverityHealSlots>
  </IsekaiAdventures.HealModifierDef>


  <!-- ============================================================ -->
