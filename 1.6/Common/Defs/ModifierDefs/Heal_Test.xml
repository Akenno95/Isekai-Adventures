  <!-- ============================================================ -->
  <!-- 4) TEST HEDIFFDEFS                                            -->
  <!-- These Hediffs only provide HealModifierDefs.                  -->
  <!-- They do not actively heal by themselves.                      -->
  <!-- Active healing will require HediffComp_HealPipeline.          -->
  <!-- ============================================================ -->


  <!-- ============================================================ -->
  <!-- TEST HEDIFF 1: Anti-Heal Curse                                -->
  <!-- How to test now:                                              -->
  <!-- 1. Injure pawn.                                               -->
  <!-- 2. Add this hediff.                                           -->
  <!-- 3. Any healing through Hediff_Injury.Heal should be blocked.  -->
  <!-- ============================================================ -->

  <HediffDef>
    <defName>Isekai_TEST_AntiHealCurse</defName>
    <label>anti-heal curse</label>
    <description>Test hediff: blocks all healing while active.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <comps>
      <li Class="IsekaiAdventures.HediffCompProperties_HealModifiers">
        <modifiers>
          <li>Isekai_HealModifier_TEST_BlockAllHealing</li>
        </modifiers>
      </li>
    </comps>
  </HediffDef>


  <!-- ============================================================ -->
  <!-- TEST HEDIFF 2A: Half Healing A                                -->
  <!-- Expected: TotalHealFactor 0.5.                                -->
  <!-- ============================================================ -->

  <HediffDef>
    <defName>Isekai_TEST_HalfHealing_A</defName>
    <label>half healing A</label>
    <description>Test hediff: multiplies all healing by 0.5.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <comps>
      <li Class="IsekaiAdventures.HediffCompProperties_HealModifiers">
        <modifiers>
          <li>Isekai_HealModifier_TEST_HalfHealing_A</li>
        </modifiers>
      </li>
    </comps>
  </HediffDef>


  <!-- ============================================================ -->
  <!-- TEST HEDIFF 2B: Half Healing B                                -->
  <!-- Add with A to test multiplicative stacking: 0.5 * 0.5 = 0.25. -->
  <!-- ============================================================ -->

  <HediffDef>
    <defName>Isekai_TEST_HalfHealing_B</defName>
    <label>half healing B</label>
    <description>Test hediff: multiplies all healing by 0.5.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <comps>
      <li Class="IsekaiAdventures.HediffCompProperties_HealModifiers">
        <modifiers>
          <li>Isekai_HealModifier_TEST_HalfHealing_B</li>
        </modifiers>
      </li>
    </comps>
  </HediffDef>


  <!-- ============================================================ -->
  <!-- TEST HEDIFF 3: Double Healing                                 -->
  <!-- Expected: TotalHealFactor 2.                                  -->
  <!-- ============================================================ -->

  <HediffDef>
    <defName>Isekai_TEST_DoubleHealing</defName>
    <label>double healing</label>
    <description>Test hediff: doubles all healing through TotalHealFactor.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <comps>
      <li Class="IsekaiAdventures.HediffCompProperties_HealModifiers">
        <modifiers>
          <li>Isekai_HealModifier_TEST_DoubleHealing</li>
        </modifiers>
      </li>
    </comps>
  </HediffDef>


  <!-- ============================================================ -->
  <!-- TEST HEDIFF 4: Body Restoration Boost                         -->
  <!-- Needs active HealPipeline comp later for visible custom heal. -->
  <!-- ============================================================ -->

  <HediffDef>
    <defName>Isekai_TEST_BodyRestorationBoost</defName>
    <label>body restoration boost</label>
    <description>Test hediff: boosts custom injury, scar and regrowth healing.</description>
