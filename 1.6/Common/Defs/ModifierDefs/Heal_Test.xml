  <!-- ============================================================ -->
  <!-- TEST HEDIFF 5: Auto Tend Boost                                -->
  <!-- Needs active HealPipeline comp later for visible auto-tend.   -->
  <!-- ============================================================ -->

  <HediffDef>
    <defName>Isekai_TEST_AutoTendBoost</defName>
    <label>auto tend boost</label>
    <description>Test hediff: boosts only automatic tending values.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <comps>
      <li Class="IsekaiAdventures.HediffCompProperties_HealModifiers">
