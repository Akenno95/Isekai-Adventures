  <!-- ============================================================ -->

  <HediffDef>
    <defName>Isekai_TEST_RegrowthSpecialist</defName>
    <label>regrowth specialist</label>
    <description>Test hediff: boosts only regrowth values.</description>
    <hediffClass>HediffWithComps</hediffClass>
