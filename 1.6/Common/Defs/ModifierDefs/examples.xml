  7.5 GeneDef extensions

  DamageModifier extension:

  <GeneDef>
    <defName>Isekai_Gene_DamageModifierExample</defName>
    <label>damage modifier gene example</label>
    <modExtensions>
      <li Class="IsekaiAdventures.DamageModifiersExtension">
        <modifiers>
          <li>Isekai_DmgMod_GlobalBlockMasteryScaling</li>
        </modifiers>
      </li>
    </modExtensions>
  </GeneDef>

