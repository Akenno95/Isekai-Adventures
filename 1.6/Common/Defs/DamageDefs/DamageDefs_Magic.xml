<?xml version="1.0" encoding="utf-8"?>
<Defs>

<!-- Damage Types -->
	<!-- Bases -->
	 	<DamageDef Abstract="true" Name="Isekai_MagicDamageBase_Ranged">
			<workerClass>DamageWorker_AddInjury</workerClass>
			<armorCategory>Isekai_Armor_Magic</armorCategory>
			<!-- <makesBlood>true</makesBlood> -->
			<externalViolence>true</externalViolence>
			<harmsHealth>true</harmsHealth>
			<hediff>Isekai_Injury_Magic</hediff>
			<!-- <hediffSolid>Isekai_Injury_Magic</hediffSolid> -->
			<!-- <harmAllLayersUntilOutside>true</harmAllLayersUntilOutside> -->
			<impactSoundType>Slice</impactSoundType>
			<overkillPctToDestroyPart>0.3~0.6</overkillPctToDestroyPart>
			<isRanged>true</isRanged>
			<makesAnimalsFlee>true</makesAnimalsFlee>
			<isExplosive>false</isExplosive>
		</DamageDef>

		<DamageDef Abstract="true" Name="Isekai_MagicDamageBase_Cut" ParentName="Isekai_MagicDamageBase_Ranged">
			<makesBlood>true</makesBlood>
			<hediff>Cut</hediff>
			<hediffSolid>Crush</hediffSolid>
			<impactSoundType>Slice</impactSoundType>
		</DamageDef>

		<DamageDef Abstract="true" Name="Isekai_MagicDamageBase_Blunt" ParentName="Isekai_MagicDamageBase_Ranged">
			<makesBlood>false</makesBlood>
			<hediff>Crush</hediff>
			<hediffSkin>Bruise</hediffSkin>
			<hediffSolid>Crack</hediffSolid>
			<impactSoundType>Blunt</impactSoundType>
		</DamageDef>

		<DamageDef Abstract="true" Name="Isekai_MagicDamageBase_Stab" ParentName="Isekai_MagicDamageBase_Ranged">
			<makesBlood>true</makesBlood>
			<hediff>Stab</hediff>
			<hediffSolid>Crush</hediffSolid>
			<impactSoundType>Stab</impactSoundType>
		</DamageDef>

		<DamageDef Abstract="true" Name="Isekai_MagicDamageBase_Burn" ParentName="Isekai_MagicDamageBase_Ranged">
			<makesBlood>false</makesBlood>
			<hediff>Burn</hediff>
			<!-- <hediffSolid>Crush</hediffSolid> -->
			<impactSoundType>Blunt</impactSoundType>
		</DamageDef>

		<DamageDef Abstract="true" Name="Isekai_MagicDamageBase_DoT" ParentName="Isekai_MagicDamageBase_Ranged">
			<makesBlood>false</makesBlood>
			<hediff>Crush</hediff>
			<hediffSkin>Bruise</hediffSkin>
			<hediffSolid>Crack</hediffSolid>
			<impactSoundType>Blunt</impactSoundType>
		</DamageDef>

<!-- Special -->
	<!-- DoT -->
		<DamageDef ParentName="Isekai_MagicDamageBase_DoT">
			<defName>Isekai_DoT_DamagePulse</defName>
			<label>damage pulse</label>
			<deathMessage>{0} was killed by an overtime effect.</deathMessage>
			<hediff>Isekai_Cut_Small</hediff>
			<!-- <hediffSolid>Crush</hediffSolid> -->
			<impactSoundType>Blunt</impactSoundType>
			<armorCategory>Isekai_Armor_Magic</armorCategory>
			<overkillPctToDestroyPart>0.3~0.6</overkillPctToDestroyPart>
			<isRanged>false</isRanged>
			<makesAnimalsFlee>true</makesAnimalsFlee>
			<isExplosive>false</isExplosive>
		</DamageDef>

